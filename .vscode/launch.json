{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug MacOS",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/telemetry_vulkan.app/Contents/MacOS/telemetry_vulkan",
      "args": [],
      // "stopAtEntry": false,
      "cwd": "${workspaceFolder}/build/telemetry_vulkan.app/Contents/MacOS/",
      // "preLaunchTask": "cmake-build", // Opzionale: un task per rebuildare prima del debug
      "externalConsole": true,        // Se vuoi vedere l'output in una console esterna
      "stopAtEntry": false,           // Se vuoi fermarti all'inizio di main()
      "environment": []
    },
    {
      "name": "Debug Windows",
      "type": "cppvsdbg",                  // usa il debugger di Visual Studio
      "request": "launch",
      "program": "${workspaceFolder}/build/telemetry_vulkan.exe",
      "args": [],
      "cwd": "${workspaceFolder}/build/",  // directory di lavoro
      "environment": [],
      "console": "externalTerminal",       // o "integratedTerminal"
      "stopAtEntry": false
    }
  ]
}
